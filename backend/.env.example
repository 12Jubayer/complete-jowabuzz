# Copy to .env and fill in production values
PORT=3001
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=jowabuzz
JWT_SECRET=
NODE_ENV=production

# Oracle Gaming API (https://oraclegames.net) — never commit real keys
ORACLE_GAMES_API_VERSION=v3
ORACLE_GAMES_V3_API_BASE_URL=https://oraclegames.net
ORACLE_GAMING_ORACHAL_KEY=
ORACLE_GAMING_DATA_KEY=
ORACLE_GAMES_CALLBACK_URL=https://jowabuzz.com/api/oracle/callback
ORACLE_GAMES_V3_TEST_GAME_UID=
ORACLE_GAMES_V3_CATALOG_FALLBACK=v2
ORACLE_GAMES_V3_LAUNCH_FALLBACK=v2

# SoftAPI SDR provider (https://767fafapi.live/api/v1) — never commit real token/secret
SOFTAPI_BASE_URL=https://767fafapi.live/api/v1
SOFTAPI_PROVIDER=SDR
SOFTAPI_TOKEN=
SOFTAPI_SECRET=
SOFTAPI_CURRENCY=BDT
SOFTAPI_LANGUAGE=bn
SOFTAPI_ENV=test
SOFTAPI_RETURN_URL=https://jowabuzz.com/game/return
SOFTAPI_CALLBACK_URL=https://jowabuzz.com/api/softapi/callback

# HMK Seamless API v1 (https://767fafapi.live/api/v1) — never commit real token/secret
HMK_API_URL=https://767fafapi.live/api/v1
HMK_CODE=HMK
HMK_TOKEN=
HMK_SECRET=
HMK_USERNAME=
HMK_CURRENCY=BDT
HMK_LANGUAGE=en
HMK_CALLBACK_URL=https://jowabuzz.com/api/hmk/callback
HMK_RETURN_URL=https://jowabuzz.com/game/return
HMK_ALLOWED_DOMAINS=
HMK_PRIMARY_PROVIDER=true

# Oracle API — set false to fully disable Oracle gaming routes/callbacks
ORACLE_ENABLED=false
ORACLE_DISABLED=true

# WinyPay Bangladesh (https://bd.gopostman.com) — never commit real keys
WINYPAY_BASE_URL=https://bd.gopostman.com
WINYPAY_MERCHANT_CODE=
WINYPAY_SECRET_KEY=
WINYPAY_PAYOUT_KEY=
WINYPAY_CURRENCY=BDT
WINYPAY_DEPOSIT_CALLBACK_URL=https://jowabuzz.com/api/payment/winypay/deposit-callback
WINYPAY_WITHDRAW_CALLBACK_URL=https://jowabuzz.com/api/payment/winypay/withdraw-callback
WINYPAY_JUMP_URL=https://jowabuzz.com/profile/deposit

# Force active payment provider (overrides admin panel when set)
PAYMENT_GATEWAY_PROVIDER=winypay
